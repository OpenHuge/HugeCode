{
  "name": "@ku0/code-application",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./runtimeExecutableSkillCatalog": {
      "types": "./src/runtimeExecutableSkillCatalog.ts",
      "default": "./src/runtimeExecutableSkillCatalog.ts"
    },
    "./runtimeExecutableSkillFacade": {
      "types": "./src/runtimeExecutableSkillFacade.ts",
      "default": "./src/runtimeExecutableSkillFacade.ts"
    },
    "./runtimeInvocationCatalog": {
      "types": "./src/runtimeInvocationCatalog.ts",
      "default": "./src/runtimeInvocationCatalog.ts"
    },
    "./runtimeInvocationCatalogFacade": {
      "types": "./src/runtimeInvocationCatalogFacade.ts",
      "default": "./src/runtimeInvocationCatalogFacade.ts"
    },
    "./runtimeBackendPreferences": {
      "types": "./src/runtimeBackendPreferences.ts",
      "default": "./src/runtimeBackendPreferences.ts"
    },
    "./runtimeConfigHooks": {
      "types": "./src/runtimeConfigHooks.ts",
      "default": "./src/runtimeConfigHooks.ts"
    },
    "./runtimeExtensionExplainability": {
      "types": "./src/runtimeExtensionExplainability.ts",
      "default": "./src/runtimeExtensionExplainability.ts"
    },
    "./runtimeLiveSkillAliases": {
      "types": "./src/runtimeLiveSkillAliases.ts",
      "default": "./src/runtimeLiveSkillAliases.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "lint": "pnpm exec oxlint src",
    "lint:fix": "pnpm exec oxlint --fix --fix-suggestions src && pnpm exec oxfmt --write ."
  },
  "dependencies": {
    "@ku0/code-platform-interfaces": "workspace:*",
    "@ku0/code-runtime-host-contract": "workspace:*",
    "@ku0/code-runtime-webmcp-client": "workspace:*",
    "@ku0/code-workspace-client": "workspace:*",
    "@ku0/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "peerDependencies": {
    "react": "^19.2.4"
  }
}
