{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime-provider-replay-manifest.schema.json",
  "title": "Runtime Provider Replay Dataset Manifest",
  "type": "object",
  "required": ["schemaVersion", "datasetId", "version", "taxonomy", "coverageMatrix", "samples"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "datasetId": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "taxonomy": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scenarioType", "status", "why"],
        "properties": {
          "scenarioType": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 },
          "why": { "type": "string", "minLength": 1 }
        }
      }
    },
    "coverageMatrix": {
      "type": "object",
      "properties": {
        "sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "modelProfiles": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "modelId",
              "family",
              "coverageRole",
              "reasoningEffort",
              "verbosity",
              "snapshotPinned",
              "status"
            ],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "modelId": { "type": "string", "minLength": 1 },
              "family": { "type": "string", "minLength": 1 },
              "coverageRole": { "type": "string", "minLength": 1 },
              "reasoningEffort": { "type": "string", "minLength": 1 },
              "verbosity": { "type": "string", "minLength": 1 },
              "snapshotPinned": { "type": "boolean" },
              "status": { "type": "string", "minLength": 1 },
              "notes": { "type": "string" }
            }
          }
        },
        "capabilityCatalog": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "status": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        },
        "capabilityRequirements": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["capabilityId", "requiredProfiles"],
            "properties": {
              "capabilityId": { "type": "string", "minLength": 1 },
              "requiredProfiles": {
                "type": "array",
                "items": { "type": "string" }
              },
              "notes": { "type": "string" }
            }
          }
        },
        "scenarioRequirements": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["scenarioType", "requiredProfiles"],
            "properties": {
              "scenarioType": { "type": "string", "minLength": 1 },
              "requiredProfiles": {
                "type": "array",
                "items": { "type": "string" }
              },
              "notes": { "type": "string" }
            }
          }
        }
      }
    },
    "samples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "file",
          "variant",
          "family",
          "scenarioType",
          "mode",
          "source",
          "recordedAt",
          "schemaVersion",
          "runtimeKind",
          "providerKind",
          "requiresRealRuntime",
          "supportsReplayOnly",
          "tags",
          "stability",
          "redactionVersion",
          "notes",
          "riskTier",
          "axisCoverage",
          "promotionPolicy",
          "freshnessPolicy"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "file": { "type": "string", "minLength": 1 },
          "variant": { "type": "string", "minLength": 1 },
          "family": { "type": "string", "minLength": 1 },
          "scenarioType": { "type": "string", "minLength": 1 },
          "mode": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 },
          "recordedAt": { "type": "string", "minLength": 1 },
          "schemaVersion": { "type": "integer", "const": 1 },
          "runtimeKind": { "type": "string", "minLength": 1 },
          "providerKind": { "type": "string", "minLength": 1 },
          "requiresRealRuntime": { "type": "boolean" },
          "supportsReplayOnly": { "type": "boolean" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "stability": { "type": "string", "minLength": 1 },
          "redactionVersion": { "type": "string", "minLength": 1 },
          "notes": { "type": "string" },
          "riskTier": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "axisCoverage": {
            "type": "object",
            "required": [
              "scenarioType",
              "failureClass",
              "modelProfile",
              "reasoningEffort",
              "accessMode",
              "backendPreference",
              "runtimeTruthCapabilities"
            ],
            "properties": {
              "scenarioType": { "type": "string", "minLength": 1 },
              "failureClass": { "type": "string", "minLength": 1 },
              "modelProfile": { "type": "string", "minLength": 1 },
              "reasoningEffort": { "type": "string", "minLength": 1 },
              "accessMode": { "type": "string", "minLength": 1 },
              "executionMode": { "type": "string", "minLength": 1 },
              "collaborationMode": { "type": "string", "minLength": 1 },
              "backendPreference": { "type": "string", "minLength": 1 },
              "runtimeTruthCapabilities": {
                "type": "array",
                "items": { "type": "string" }
              },
              "interactionStrength": { "type": "string", "minLength": 1 },
              "coverageSlice": { "type": "string", "minLength": 1 }
            }
          },
          "promotionPolicy": {
            "type": "object",
            "required": [
              "minimumTraceGrade",
              "requiresRecordedEvidence",
              "requiresDeterministicRegression",
              "requiresLiveFailureProbe",
              "blockingTrack"
            ],
            "properties": {
              "minimumTraceGrade": { "type": "number" },
              "requiresRecordedEvidence": { "type": "boolean" },
              "requiresDeterministicRegression": { "type": "boolean" },
              "requiresLiveFailureProbe": { "type": "boolean" },
              "blockingTrack": { "type": "boolean" }
            }
          },
          "freshnessPolicy": {
            "type": "object",
            "required": [
              "maxAgeDays",
              "maxDebtDays",
              "strict",
              "refreshOnModelChange",
              "refreshOnRuntimeTruthDrift",
              "refreshOnFailureClassDrift"
            ],
            "properties": {
              "maxAgeDays": { "type": "integer" },
              "maxDebtDays": { "type": "integer" },
              "strict": { "type": "boolean" },
              "refreshOnModelChange": { "type": "boolean" },
              "refreshOnRuntimeTruthDrift": { "type": "boolean" },
              "refreshOnFailureClassDrift": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
